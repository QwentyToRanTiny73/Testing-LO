---
import { getCollection } from 'astro:content';
import { modules } from '../../data/modules';

interface Props {
  currentModule: string;
  currentLesson?: string;
}
const { currentModule, currentLesson } = Astro.props;
const base = import.meta.env.BASE_URL;

const allLessons = await getCollection('lessons');
const moduleMap = new Map<string, typeof allLessons>();
for (const lesson of allLessons) {
  const mod = lesson.data.module;
  if (!moduleMap.has(mod)) moduleMap.set(mod, []);
  moduleMap.get(mod)!.push(lesson);
}
for (const [, lessons] of moduleMap) {
  lessons.sort((a, b) => a.data.order - b.data.order);
}
---

<nav class="text-sm">
  <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-3 px-2">Модули курса</h2>
  <ul class="space-y-1">
    {modules.map(mod => {
      const lessons = moduleMap.get(mod.id) || [];
      const isOpen = mod.id === currentModule;
      return (
        <li>
          <a
            href={`${base}course/${mod.id}`}
            class={`flex items-center gap-2 px-2 py-1.5 rounded-lg font-medium transition-colors
              ${mod.id === currentModule
                ? 'bg-wine-50 text-wine-800 dark:bg-wine-950/50 dark:text-wine-300'
                : 'text-stone-600 hover:bg-stone-100 dark:text-stone-400 dark:hover:bg-stone-800'}`}
          >
            <span>{mod.icon}</span>
            <span class="flex-1 truncate">{mod.title}</span>
            <span class="text-xs text-stone-400 dark:text-stone-500">{lessons.length}</span>
          </a>

          {isOpen && lessons.length > 0 && (
            <ul class="mt-1 ml-6 space-y-0.5">
              {lessons.map(lesson => {
                const lessonPath = `${mod.id}/${lesson.slug.split('/').pop()}`;
                const isCurrent = lesson.id === currentLesson || lesson.slug === currentLesson;
                return (
                  <li>
                    <a
                      href={`${base}course/${lessonPath}`}
                      class={`flex items-center gap-2 px-2 py-1 rounded text-xs transition-colors
                        ${isCurrent
                          ? 'text-wine-700 dark:text-wine-400 font-medium'
                          : 'text-stone-500 hover:text-stone-800 dark:text-stone-500 dark:hover:text-stone-300'}`}
                    >
                      <span
                        class="progress-check w-3.5 h-3.5 rounded-full border flex-shrink-0 flex items-center justify-center transition-colors border-stone-300 dark:border-stone-600"
                        data-lesson-id={lesson.id}
                      ></span>
                      <span class="truncate">{lesson.data.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </li>
      );
    })}
  </ul>
</nav>

<script>
  // Update progress checkmarks
  function updateSidebarProgress() {
    const stored = JSON.parse(localStorage.getItem('lesson-progress') || '{}');
    document.querySelectorAll<HTMLElement>('.progress-check[data-lesson-id]').forEach(el => {
      const id = el.dataset.lessonId;
      if (id && stored[id]) {
        el.classList.add('bg-green-500', 'border-green-500');
        el.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
      }
    });
  }
  updateSidebarProgress();
  window.addEventListener('storage', updateSidebarProgress);
  document.addEventListener('lesson-completed', updateSidebarProgress);
</script>
