---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { courses } from '../data/courses';
import { modules, getModulesByCourse } from '../data/modules';

const base = import.meta.env.BASE_URL;
const allLessons = await getCollection('lessons');

const moduleCourse = new Map(modules.map((m) => [m.id, m.course]));
const courseStats = new Map<string, { lessons: number; minutes: number; modules: number }>();
for (const c of courses) courseStats.set(c.id, { lessons: 0, minutes: 0, modules: getModulesByCourse(c.id).length });
for (const l of allLessons) {
  const cid = moduleCourse.get(l.data.module);
  if (cid && courseStats.has(cid)) {
    const s = courseStats.get(cid)!;
    s.lessons += 1;
    s.minutes += l.data.durationMin;
  }
}
const totalLessons = allLessons.length;
const sortedCourses = [...courses].sort((a, b) => a.order - b.order);

const features = [
  { icon: '🧮', title: 'Калькуляторы', desc: 'SO₂, мацерация, бентонит, сахар, кислотность, Brix', href: `${base}tools` },
  { icon: '🃏', title: 'Флэш-карты', desc: 'Интервальное повторение по алгоритму SM-2', href: `${base}study` },
  { icon: '❓', title: 'Квизы', desc: 'Проверка понимания по методу Сократа', href: `${base}quiz` },
  { icon: '📖', title: 'Глоссарий', desc: 'Термины технологии и энологии с пояснениями', href: `${base}glossary` },
];
---

<BaseLayout title="Школа виноделия">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-wine-900 via-wine-800 to-indigo-950 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-5xl mb-6">🍷</div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">Школа виноделия</h1>
      <p class="text-xl text-stone-200 mb-2">Практическая технология и научная энология</p>
      <p class="text-stone-300 max-w-2xl mx-auto mb-8">
        Два взаимодополняющих курса: один ведёт через производственный процесс шаг за шагом,
        другой объясняет химию и биохимию вина. Эффективные методы обучения, калькуляторы и
        интервальное повторение. Все числовые значения — ориентиры, а не нормы.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}courses`} class="inline-flex items-center gap-2 bg-white text-wine-800 px-6 py-3 rounded-xl font-semibold hover:bg-stone-100 transition-colors">
          Выбрать курс
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href={`${base}tools`} class="inline-flex items-center gap-2 border border-white/40 text-white px-6 py-3 rounded-xl font-semibold hover:bg-white/10 transition-colors">
          Калькуляторы
        </a>
      </div>
    </div>
  </section>

  <!-- Platform stats -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400">{courses.length}</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Курса</div>
      </div>
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400">{modules.length}</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Модулей</div>
      </div>
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400">{totalLessons}</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Уроков</div>
      </div>
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400" id="completed-count">0</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Пройдено</div>
      </div>
    </div>
  </section>

  <!-- Courses -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-4">
    <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-6">Три курса</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedCourses.map((course) => {
        const s = courseStats.get(course.id)!;
        const isSim = course.kind === 'simulation';
        const cardHref = isSim ? `${base}${course.href}` : `${base}courses/${course.id}`;
        return (
          <a href={cardHref}
            class={`rounded-2xl border border-stone-200 dark:border-stone-800 overflow-hidden flex flex-col transition-all ${course.accent.borderHover} hover:shadow-lg group`}>
            <div class={`bg-gradient-to-br ${course.accent.gradient} text-white p-6`}>
              <div class="flex items-center justify-between mb-3">
                <span class="text-4xl">{course.icon}</span>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-white/15 backdrop-blur">{course.level}</span>
              </div>
              <h3 class="text-2xl font-bold mb-1">{course.title}</h3>
              <p class="text-sm text-white/80">{course.subtitle}</p>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <p class="text-sm text-stone-600 dark:text-stone-400 mb-4 line-clamp-3">{course.description}</p>
              <div class="flex flex-wrap gap-2 text-xs text-stone-500 dark:text-stone-400 mb-4 mt-auto">
                {isSim && course.stats
                  ? course.stats.slice(0, 2).map((st, i) => (
                      <span class={i === 0 ? `px-2 py-1 rounded-md ${course.accent.soft} ${course.accent.text} font-medium` : 'px-2 py-1 rounded-md bg-stone-100 dark:bg-stone-800'}>{st.value} {st.label}</span>
                    ))
                  : (
                    <>
                      <span class={`px-2 py-1 rounded-md ${course.accent.soft} ${course.accent.text} font-medium`}>{s.modules} модулей</span>
                      <span class="px-2 py-1 rounded-md bg-stone-100 dark:bg-stone-800">{s.lessons} уроков</span>
                    </>
                  )}
              </div>
              <span class={`text-sm font-semibold ${course.accent.text} group-hover:underline`}>{isSim ? 'Открыть тренажёр →' : 'Открыть курс →'}</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Features -->
  <section class="bg-stone-100 dark:bg-stone-900 py-16 px-4 mt-12">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-2">Инструменты и тренажёры</h2>
      <p class="text-stone-500 dark:text-stone-400 mb-8">Доступны для обоих курсов</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {features.map((f) => (
          <a href={f.href} class="card hover:border-wine-300 dark:hover:border-wine-700 hover:shadow-md transition-all group">
            <div class="text-2xl mb-2">{f.icon}</div>
            <h3 class="font-semibold text-stone-800 dark:text-stone-200 group-hover:text-wine-700 dark:group-hover:text-wine-400 transition-colors mb-1">{f.title}</h3>
            <p class="text-xs text-stone-500 dark:text-stone-400">{f.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function updateHomeProgress() {
    const stored = JSON.parse(localStorage.getItem('lesson-progress') || '{}');
    const completed = Object.values(stored).filter(Boolean).length;
    const el = document.getElementById('completed-count');
    if (el) el.textContent = String(completed);
  }
  updateHomeProgress();
  window.addEventListener('storage', updateHomeProgress);
</script>
