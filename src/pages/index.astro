---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { modules } from '../data/modules';
import ModuleProgressBar from '../components/course/ModuleProgressBar.astro';

const allLessons = await getCollection('lessons');
const lessonsByModule = new Map<string, number>();
for (const l of allLessons) {
  lessonsByModule.set(l.data.module, (lessonsByModule.get(l.data.module) || 0) + 1);
}
const totalLessons = allLessons.length;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Курс по виноделию">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-wine-900 via-wine-800 to-oak-900 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-5xl mb-6">🍷</div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">
        Технология виноделия
      </h1>
      <p class="text-xl text-wine-200 mb-2">Школа Магарача · ВНИИВиВ «Магарач» · Крым</p>
      <p class="text-wine-300 max-w-2xl mx-auto mb-8">
        Структурированный курс по классической технологии виноделия с культурными дрожжами,
        стандартным арсеналом обработок и практическими калькуляторами.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}course`} class="inline-flex items-center gap-2 bg-white text-wine-800 px-6 py-3 rounded-xl font-semibold hover:bg-wine-50 transition-colors">
          Начать курс
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={`${base}tools`} class="inline-flex items-center gap-2 border border-wine-400 text-wine-100 px-6 py-3 rounded-xl font-semibold hover:bg-wine-800 transition-colors">
          Калькуляторы
        </a>
      </div>
    </div>
  </section>

  <!-- Stats + Continue button -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400">{modules.length}</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Модулей</div>
      </div>
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400">{totalLessons}</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Уроков</div>
      </div>
      <div class="card text-center">
        <div class="text-3xl font-bold text-wine-700 dark:text-wine-400" id="completed-count">0</div>
        <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Пройдено</div>
      </div>
    </div>

    <!-- Course progress -->
    <div class="card mb-8" id="course-progress-card">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-stone-800 dark:text-stone-200">Ваш прогресс</h2>
        <div class="flex gap-3 items-center">
          <span class="text-sm text-stone-500" id="course-pct">0%</span>
          <button id="continue-btn" class="btn-primary text-xs">Продолжить →</button>
        </div>
      </div>
      <div class="h-2.5 bg-stone-200 dark:bg-stone-700 rounded-full overflow-hidden">
        <div id="course-progress-bar" class="h-full bg-wine-600 rounded-full transition-all duration-500" style="width:0%"></div>
      </div>
      <div class="flex justify-between mt-2 text-xs text-stone-400">
        <span>0</span>
        <span id="progress-label">0 / {totalLessons} уроков</span>
        <span>{totalLessons}</span>
      </div>
    </div>
  </section>

  <!-- Modules grid -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-6">Модули курса</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {modules.map(mod => (
        <a
          href={`${base}course/${mod.id}`}
          class="card hover:border-wine-300 dark:hover:border-wine-700 hover:shadow-md transition-all group"
        >
          <div class="flex items-start gap-3 mb-3">
            <span class="text-2xl">{mod.icon}</span>
            <div class="flex-1 min-w-0">
              <div class="text-xs text-stone-400 dark:text-stone-500 mb-0.5">Модуль {mod.order}</div>
              <h3 class="font-semibold text-stone-800 dark:text-stone-200 group-hover:text-wine-700 dark:group-hover:text-wine-400 transition-colors leading-tight">
                {mod.title}
              </h3>
            </div>
          </div>
          <p class="text-sm text-stone-500 dark:text-stone-400 line-clamp-2 mb-3">{mod.description}</p>
          <div class="flex items-center justify-between text-xs text-stone-400 dark:text-stone-500 mb-2">
            <span>{lessonsByModule.get(mod.id) || 0} уроков</span>
          </div>
          <ModuleProgressBar moduleId={mod.id} />
        </a>
      ))}
    </div>
  </section>

  <!-- Tools preview -->
  <section class="bg-stone-100 dark:bg-stone-900 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-2">Инструменты винодела</h2>
      <p class="text-stone-500 dark:text-stone-400 mb-8">Практические калькуляторы для расчётов в процессе производства</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { title: 'Мацерация красных', desc: 'Рекомендованный диапазон дней мацерации по сорту и стилю', href: `${base}tools#maceration` },
          { title: 'Сульфитирование', desc: 'Расчёт молекулярного SO₂ и навески метабисульфита', href: `${base}tools#so2` },
          { title: 'Пробная оклейка', desc: 'Подбор дозы бентонита по результатам теплового теста', href: `${base}tools#bentonite` },
        ].map(t => (
          <a href={t.href} class="card hover:border-wine-300 dark:hover:border-wine-700 hover:shadow-md transition-all group">
            <div class="text-wine-600 dark:text-wine-400 text-xl mb-2">⚗️</div>
            <h3 class="font-semibold text-stone-800 dark:text-stone-200 group-hover:text-wine-700 dark:group-hover:text-wine-400 transition-colors mb-1">{t.title}</h3>
            <p class="text-xs text-stone-500 dark:text-stone-400">{t.desc}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href={`${base}tools`} class="btn-secondary">Все калькуляторы →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ totalLessons }}>
  function updateHomepageProgress() {
    const stored = JSON.parse(localStorage.getItem('lesson-progress') || '{}');
    const completed = Object.values(stored).filter(Boolean).length;
    const pct = totalLessons > 0 ? Math.round((completed / totalLessons) * 100) : 0;

    const el = document.getElementById('completed-count');
    if (el) el.textContent = String(completed);

    const bar = document.getElementById('course-progress-bar');
    if (bar) bar.style.width = `${pct}%`;

    const pctEl = document.getElementById('course-pct');
    if (pctEl) pctEl.textContent = `${pct}%`;

    const label = document.getElementById('progress-label');
    if (label) label.textContent = `${completed} / ${totalLessons} уроков`;
  }

  updateHomepageProgress();
  window.addEventListener('storage', updateHomepageProgress);

  // Continue button — navigate to first uncompleted lesson
  const continueBtn = document.getElementById('continue-btn');
  if (continueBtn) {
    continueBtn.addEventListener('click', () => {
      window.location.href = '/Testing-LO/course';
    });
  }
</script>
