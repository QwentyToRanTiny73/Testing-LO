---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import { getCollection } from 'astro:content';
import { modules, getModuleById } from '../../../data/modules';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  const moduleCourse = new Map(modules.map(m => [m.id, m.course]));
  const moduleOrder = new Map(modules.map(m => [m.id, m.order]));

  // Sort all lessons by course, then module order, then lesson order
  const sortedLessons = [...allLessons].sort((a, b) => {
    const modA = moduleOrder.get(a.data.module) ?? 99;
    const modB = moduleOrder.get(b.data.module) ?? 99;
    if (modA !== modB) return modA - modB;
    return a.data.order - b.data.order;
  });

  return allLessons.map(lesson => {
    // Prev/next stay within the same course
    const courseId = moduleCourse.get(lesson.data.module);
    const courseLessons = sortedLessons.filter(l => moduleCourse.get(l.data.module) === courseId);
    const idx = courseLessons.findIndex(l => l.id === lesson.id);
    const prevLesson = idx > 0 ? courseLessons[idx - 1] : undefined;
    const nextLesson = idx < courseLessons.length - 1 ? courseLessons[idx + 1] : undefined;

    const slugParts = lesson.slug.split('/');
    const lessonSlug = slugParts[slugParts.length - 1];

    function getLessonHref(l: typeof lesson) {
      const parts = l.slug.split('/');
      return `${l.data.module}/${parts[parts.length - 1]}`;
    }

    return {
      params: {
        module: lesson.data.module,
        lesson: lessonSlug,
      },
      props: {
        lesson,
        prevLesson: prevLesson ? { title: prevLesson.data.title, slug: getLessonHref(prevLesson) } : undefined,
        nextLesson: nextLesson ? { title: nextLesson.data.title, slug: getLessonHref(nextLesson) } : undefined,
      },
    };
  });
}

const { lesson, prevLesson, nextLesson } = Astro.props;
const { Content, headings } = await lesson.render();
---

<LessonLayout lesson={lesson} headings={headings} prevLesson={prevLesson} nextLesson={nextLesson}>
  <Content />
</LessonLayout>
