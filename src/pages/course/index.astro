---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { modules } from '../../data/modules';
import ModuleProgressBar from '../../components/course/ModuleProgressBar.astro';

const allLessons = await getCollection('lessons');
const lessonsByModule = new Map<string, typeof allLessons>();
for (const l of allLessons) {
  if (!lessonsByModule.has(l.data.module)) lessonsByModule.set(l.data.module, []);
  lessonsByModule.get(l.data.module)!.push(l);
}

const totalMinutes = allLessons.reduce((s, l) => s + l.data.durationMin, 0);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Курс по виноделию" description="Все модули обучающего курса по технологии виноделия">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-stone-500 mb-4">
        <a href={base} class="hover:text-wine-700">Главная</a>
        <span>/</span>
        <span class="text-stone-700 dark:text-stone-300">Курс</span>
      </nav>
      <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-2">Курс по технологии виноделия</h1>
      <p class="text-stone-500 dark:text-stone-400 mb-6">
        {modules.length} модулей · {allLessons.length} уроков · ≈{Math.round(totalMinutes / 60)} часов материала
      </p>

      <!-- Overall progress -->
      <div class="card mb-2" id="overall-progress">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-stone-700 dark:text-stone-300">Общий прогресс</span>
          <span class="text-sm text-wine-700 dark:text-wine-400" id="overall-pct">0%</span>
        </div>
        <div class="h-2 bg-stone-200 dark:bg-stone-700 rounded-full overflow-hidden">
          <div id="overall-bar" class="h-full bg-wine-600 rounded-full transition-all" style="width:0%"></div>
        </div>
      </div>
      <button id="reset-progress" class="text-xs text-stone-400 hover:text-red-500 transition-colors mt-1">
        Сбросить прогресс
      </button>
    </div>

    <!-- Modules list -->
    <div class="space-y-4">
      {modules.map(mod => {
        const lessons = (lessonsByModule.get(mod.id) || []).sort((a, b) => a.data.order - b.data.order);
        const totalTime = lessons.reduce((s, l) => s + l.data.durationMin, 0);
        return (
          <div class="card hover:border-wine-300 dark:hover:border-wine-700 transition-all">
            <div class="flex items-start gap-4">
              <span class="text-3xl mt-0.5">{mod.icon}</span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                  <div>
                    <span class="text-xs text-stone-400 dark:text-stone-500">Модуль {mod.order}</span>
                    <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-200">
                      <a href={`${base}course/${mod.id}`} class="hover:text-wine-700 dark:hover:text-wine-400 transition-colors">
                        {mod.title}
                      </a>
                    </h2>
                  </div>
                  <div class="text-right text-xs text-stone-400 dark:text-stone-500">
                    <div>{lessons.length} уроков</div>
                    <div>≈{totalTime} мин</div>
                  </div>
                </div>
                <p class="text-sm text-stone-500 dark:text-stone-400 mb-3">{mod.description}</p>
                <ModuleProgressBar moduleId={mod.id} />
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>

<script define:vars={{ totalLessons: allLessons.length }}>
  function updateProgress() {
    const stored = JSON.parse(localStorage.getItem('lesson-progress') || '{}');
    const completed = Object.values(stored).filter(Boolean).length;
    const pct = totalLessons > 0 ? Math.round((completed / totalLessons) * 100) : 0;
    const bar = document.getElementById('overall-bar');
    const pctEl = document.getElementById('overall-pct');
    if (bar) bar.style.width = `${pct}%`;
    if (pctEl) pctEl.textContent = `${pct}%`;
  }

  updateProgress();
  window.addEventListener('storage', updateProgress);

  document.getElementById('reset-progress')?.addEventListener('click', () => {
    if (confirm('Сбросить весь прогресс?')) {
      localStorage.removeItem('lesson-progress');
      updateProgress();
      document.querySelectorAll<HTMLElement>('.module-progress-bar').forEach(b => { b.style.width = '0%'; });
      document.querySelectorAll('.module-progress-text').forEach(t => {
        const total = t.textContent?.split('/')[1]?.trim() || '0';
        t.textContent = `0 / ${total}`;
      });
    }
  });
</script>
