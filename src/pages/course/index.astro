---
// The course catalog now lives at /courses. This page redirects there
// to keep any old links working.
const base = import.meta.env.BASE_URL;
const target = `${base}courses`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Курсы</title>
  </head>
  <body>
    <p>Переход к <a href={target}>каталогу курсов</a>…</p>
    <script is:inline set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </body>
</html>
