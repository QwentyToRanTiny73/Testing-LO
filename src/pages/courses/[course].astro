---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModuleProgressBar from '../../components/course/ModuleProgressBar.astro';
import { getCollection } from 'astro:content';
import { courses, getCourseById } from '../../data/courses';
import { getModulesByCourse } from '../../data/modules';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  return courses.filter((course) => course.kind !== 'simulation').map((course) => {
    const courseModules = getModulesByCourse(course.id);
    const lessonsByModule = new Map<string, typeof allLessons>();
    for (const m of courseModules) lessonsByModule.set(m.id, []);
    for (const l of allLessons) {
      if (lessonsByModule.has(l.data.module)) lessonsByModule.get(l.data.module)!.push(l);
    }
    for (const [, arr] of lessonsByModule) arr.sort((a, b) => a.data.order - b.data.order);

    const allCourseLessons = courseModules.flatMap((m) => lessonsByModule.get(m.id) || []);
    return {
      params: { course: course.id },
      props: { course, courseModules, lessonsByModule, lessonIds: allCourseLessons.map((l) => l.id) },
    };
  });
}

const { course, courseModules, lessonsByModule, lessonIds } = Astro.props;
const base = import.meta.env.BASE_URL;

const totalLessons = lessonIds.length;
const totalMinutes = courseModules
  .flatMap((m) => lessonsByModule.get(m.id) || [])
  .reduce((s, l) => s + l.data.durationMin, 0);

// First lesson to start from
const firstModule = courseModules[0];
const firstLessons = firstModule ? lessonsByModule.get(firstModule.id) || [] : [];
const firstLesson = firstLessons[0];
const firstHref = firstLesson
  ? `${base}course/${firstModule.id}/${firstLesson.slug.split('/').pop()}`
  : `${base}courses`;
---

<BaseLayout title={course.title} description={course.description}>
  <!-- Hero -->
  <section class={`bg-gradient-to-br ${course.accent.gradient} text-white py-16 px-4`}>
    <div class="max-w-5xl mx-auto">
      <nav class="flex items-center gap-2 text-sm text-white/70 mb-6">
        <a href={base} class="hover:text-white">Главная</a>
        <span>/</span>
        <a href={`${base}courses`} class="hover:text-white">Курсы</a>
        <span>/</span>
        <span class="text-white">{course.title}</span>
      </nav>
      <div class="flex items-start gap-4 mb-4">
        <span class="text-5xl">{course.icon}</span>
        <div>
          <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-white/15 backdrop-blur">{course.level}</span>
          <h1 class="text-3xl sm:text-4xl font-bold mt-2">{course.title}</h1>
          <p class="text-lg text-white/80 mt-1">{course.subtitle}</p>
        </div>
      </div>
      <p class="text-white/85 max-w-3xl mb-6">{course.description}</p>
      <div class="flex flex-wrap gap-3 items-center">
        <a href={firstHref} class="inline-flex items-center gap-2 bg-white text-stone-900 px-6 py-3 rounded-xl font-semibold hover:bg-stone-100 transition-colors">
          Начать обучение
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <span class="text-sm text-white/70">{courseModules.length} модулей · {totalLessons} уроков · ≈{Math.round(totalMinutes / 60)} ч</span>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <!-- Course progress -->
    <div class="card mb-10" id="course-progress-card">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-stone-800 dark:text-stone-200">Ваш прогресс по курсу</h2>
        <span class={`text-sm ${course.accent.text}`} id="course-pct">0%</span>
      </div>
      <div class="h-2.5 bg-stone-200 dark:bg-stone-700 rounded-full overflow-hidden">
        <div id="course-progress-bar" class={`h-full ${course.accent.bg} rounded-full transition-all duration-500`} style="width:0%"></div>
      </div>
      <div class="text-xs text-stone-400 mt-2" id="progress-label">0 / {totalLessons} уроков</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left: outcomes + audience + format -->
      <aside class="space-y-6">
        <div class="card">
          <h3 class="font-semibold text-stone-800 dark:text-stone-200 mb-3">Чему вы научитесь</h3>
          <ul class="space-y-2">
            {course.outcomes.map((o) => (
              <li class="flex gap-2 text-sm text-stone-600 dark:text-stone-400">
                <span class={course.accent.text}>✓</span><span>{o}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card">
          <h3 class="font-semibold text-stone-800 dark:text-stone-200 mb-3">Для кого курс</h3>
          <ul class="space-y-2">
            {course.audience.map((a) => (
              <li class="flex gap-2 text-sm text-stone-600 dark:text-stone-400">
                <span class="text-stone-400">•</span><span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card">
          <h3 class="font-semibold text-stone-800 dark:text-stone-200 mb-3">Формат обучения</h3>
          <ul class="space-y-3">
            {course.format.map((f) => (
              <li class="flex gap-3">
                <span class="text-xl">{f.icon}</span>
                <div>
                  <div class="text-sm font-medium text-stone-700 dark:text-stone-300">{f.label}</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">{f.desc}</div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Right: program -->
      <div class="lg:col-span-2">
        <h2 class="text-xl font-bold text-stone-800 dark:text-stone-200 mb-4">Программа курса</h2>
        <div class="space-y-3">
          {courseModules.map((mod) => {
            const lessons = lessonsByModule.get(mod.id) || [];
            const t = lessons.reduce((s, l) => s + l.data.durationMin, 0);
            return (
              <div class={`card transition-all ${course.accent.borderHover}`}>
                <div class="flex items-start gap-4">
                  <span class="text-2xl mt-0.5">{mod.icon}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                      <div>
                        <span class="text-xs text-stone-400 dark:text-stone-500">Модуль {mod.order}</span>
                        <h3 class="font-semibold text-stone-800 dark:text-stone-200">
                          <a href={`${base}course/${mod.id}`} class={`hover:underline ${course.accent.text}`}>{mod.title}</a>
                        </h3>
                      </div>
                      <div class="text-right text-xs text-stone-400 dark:text-stone-500">
                        <div>{lessons.length} уроков</div>
                        <div>≈{t} мин</div>
                      </div>
                    </div>
                    <p class="text-sm text-stone-500 dark:text-stone-400 mb-3">{mod.description}</p>
                    <ModuleProgressBar moduleId={mod.id} />
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ lessonIds }}>
  function updateCourseProgress() {
    const stored = JSON.parse(localStorage.getItem('lesson-progress') || '{}');
    const total = lessonIds.length;
    const done = lessonIds.filter((id) => stored[id]).length;
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;
    const bar = document.getElementById('course-progress-bar');
    if (bar) bar.style.width = `${pct}%`;
    const pctEl = document.getElementById('course-pct');
    if (pctEl) pctEl.textContent = `${pct}%`;
    const label = document.getElementById('progress-label');
    if (label) label.textContent = `${done} / ${total} уроков`;
  }
  updateCourseProgress();
  window.addEventListener('storage', updateCourseProgress);
</script>
