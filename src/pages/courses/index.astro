---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { courses } from '../../data/courses';
import { modules, getModulesByCourse } from '../../data/modules';

const base = import.meta.env.BASE_URL;
const allLessons = await getCollection('lessons');

// lesson count + minutes per course (derived via module → course)
const moduleCourse = new Map(modules.map((m) => [m.id, m.course]));
const stats = new Map<string, { lessons: number; minutes: number; modules: number }>();
for (const c of courses) stats.set(c.id, { lessons: 0, minutes: 0, modules: getModulesByCourse(c.id).length });
for (const l of allLessons) {
  const cid = moduleCourse.get(l.data.module);
  if (!cid || !stats.has(cid)) continue;
  const s = stats.get(cid)!;
  s.lessons += 1;
  s.minutes += l.data.durationMin;
}

const methodology = [
  { icon: '🎯', title: 'Активное вспоминание', desc: 'Каждый урок завершается ключевыми выводами и вопросами «проверь себя» — вы не перечитываете, а воспроизводите.' },
  { icon: '🃏', title: 'Интервальное повторение', desc: 'Флэш-карты по алгоритму SM-2 показывают материал ровно в тот момент, когда он начинает забываться.' },
  { icon: '🧠', title: 'Мнемоника', desc: 'Сложные закономерности упакованы в запоминающиеся образы и формулы.' },
  { icon: '❓', title: 'Метод Сократа', desc: 'Квизы спрашивают «почему», ведут к пониманию механизма, а не к зубрёжке ответа.' },
  { icon: '🗺', title: 'Майндкарты', desc: 'Структура темы видна целиком — связи между понятиями, а не разрозненные факты.' },
  { icon: '📈', title: 'Прогресс и заметки', desc: 'Отметки о прохождении и личные заметки к урокам сохраняются в браузере.' },
];
---

<BaseLayout title="Курсы" description="Два курса по виноделию: практическая технология и научная энология">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-wine-900 via-wine-800 to-indigo-950 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-5xl mb-6">🍇</div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">Школа виноделия</h1>
      <p class="text-xl text-stone-200 mb-3">Два пути к мастерству: практика и наука</p>
      <p class="text-stone-300 max-w-2xl mx-auto">
        Выберите курс под свою цель. Практикум ведёт через технологический процесс шаг за шагом;
        энология объясняет, что происходит на молекулярном уровне. Курсы дополняют друг друга.
      </p>
    </div>
  </section>

  <!-- Course catalog -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
    <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-6">Каталог курсов</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {courses.sort((a, b) => a.order - b.order).map((course) => {
        const s = stats.get(course.id)!;
        const isSim = course.kind === 'simulation';
        const cardHref = isSim ? `${base}${course.href}` : `${base}courses/${course.id}`;
        return (
          <div class={`rounded-2xl border border-stone-200 dark:border-stone-800 overflow-hidden flex flex-col transition-all ${course.accent.borderHover} hover:shadow-lg`}>
            <div class={`bg-gradient-to-br ${course.accent.gradient} text-white p-6`}>
              <div class="flex items-center justify-between mb-3">
                <span class="text-4xl">{course.icon}</span>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-white/15 backdrop-blur">{course.level}</span>
              </div>
              <h3 class="text-2xl font-bold mb-1">{course.title}</h3>
              <p class="text-sm text-white/80">{course.subtitle}</p>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <p class="text-sm text-stone-600 dark:text-stone-400 mb-4">{course.description}</p>
              <div class="flex flex-wrap gap-3 text-xs text-stone-500 dark:text-stone-400 mb-5">
                {isSim && course.stats
                  ? course.stats.map((st, i) => (
                      <span class={i === 0 ? `px-2 py-1 rounded-md ${course.accent.soft} ${course.accent.text} font-medium` : 'px-2 py-1 rounded-md bg-stone-100 dark:bg-stone-800'}>{st.value} {st.label}</span>
                    ))
                  : (
                    <>
                      <span class={`px-2 py-1 rounded-md ${course.accent.soft} ${course.accent.text} font-medium`}>{s.modules} модулей</span>
                      <span class="px-2 py-1 rounded-md bg-stone-100 dark:bg-stone-800">{s.lessons} уроков</span>
                      <span class="px-2 py-1 rounded-md bg-stone-100 dark:bg-stone-800">≈{Math.round(s.minutes / 60)} ч материала</span>
                    </>
                  )}
              </div>
              <div class="mb-5">
                <div class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-wide mb-2">Чему вы научитесь</div>
                <ul class="space-y-1.5">
                  {course.outcomes.slice(0, 4).map((o) => (
                    <li class="flex gap-2 text-sm text-stone-600 dark:text-stone-400">
                      <span class={course.accent.text}>✓</span>
                      <span>{o}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mt-auto flex gap-3">
                <a href={cardHref}
                  class={`flex-1 text-center text-white ${course.accent.bg} ${course.accent.bgHover} px-4 py-2.5 rounded-xl font-semibold text-sm transition-colors`}>
                  {isSim ? 'Открыть тренажёр →' : 'Открыть курс →'}
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Methodology -->
  <section class="bg-stone-100 dark:bg-stone-900 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-2">Как устроено обучение</h2>
      <p class="text-stone-500 dark:text-stone-400 mb-8">Оба курса используют доказанные методы эффективного обучения</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {methodology.map((m) => (
          <div class="card">
            <div class="text-2xl mb-2">{m.icon}</div>
            <h3 class="font-semibold text-stone-800 dark:text-stone-200 mb-1">{m.title}</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
