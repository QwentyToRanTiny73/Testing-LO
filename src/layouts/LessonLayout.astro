---
import BaseLayout from './BaseLayout.astro';
import ModuleSidebar from '../components/course/ModuleSidebar.astro';
import LessonTOC from '../components/course/LessonTOC.astro';
import Breadcrumbs from '../components/course/Breadcrumbs.astro';
import LessonProgress from '../components/course/LessonProgress.astro';
import KeyPoints from '../components/learning/KeyPoints';
import LessonNotes from '../components/learning/LessonNotes';
import type { CollectionEntry } from 'astro:content';
import { getModuleById } from '../data/modules';
import { quizQuestions } from '../data/quizzes';
import { flashcards } from '../data/flashcards';

interface Props {
  lesson: CollectionEntry<'lessons'>;
  headings: { depth: number; slug: string; text: string }[];
  prevLesson?: { title: string; slug: string };
  nextLesson?: { title: string; slug: string };
}

const { lesson, headings, prevLesson, nextLesson } = Astro.props;
const module = getModuleById(lesson.data.module);
const base = import.meta.env.BASE_URL;

// Related quizzes and flashcards for this module
const moduleQuizCount = quizQuestions.filter(q => q.moduleId === lesson.data.module).length;
const moduleCardCount = flashcards.filter(f => f.moduleId === lesson.data.module).length;
---

<BaseLayout title={lesson.data.title} description={lesson.data.summary}>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-8">
      <!-- Left Sidebar -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24 space-y-6">
          <ModuleSidebar currentModule={lesson.data.module} currentLesson={lesson.id} />

          <!-- Quick links for this module -->
          {(moduleQuizCount > 0 || moduleCardCount > 0) && (
            <div class="rounded-xl border border-stone-200 dark:border-stone-800 p-4 space-y-2">
              <div class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-wide mb-3">Тренировка</div>
              {moduleCardCount > 0 && (
                <a href={`${base}study?module=${lesson.data.module}`}
                  class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400 hover:text-wine-700 dark:hover:text-wine-400 transition-colors">
                  <span>🃏</span>
                  <span>Флэш-карты ({moduleCardCount})</span>
                </a>
              )}
              {moduleQuizCount > 0 && (
                <a href={`${base}quiz?module=${lesson.data.module}`}
                  class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400 hover:text-wine-700 dark:hover:text-wine-400 transition-colors">
                  <span>❓</span>
                  <span>Квиз ({moduleQuizCount} вопроса)</span>
                </a>
              )}
            </div>
          )}
        </div>
      </aside>

      <!-- Main content -->
      <article class="flex-1 min-w-0 max-w-3xl">
        <Breadcrumbs module={module} lessonTitle={lesson.data.title} />

        <header class="mb-8">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class={`text-xs px-2 py-0.5 rounded-full font-medium
              ${lesson.data.difficulty === 'базовый' ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' :
                lesson.data.difficulty === 'средний' ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300' :
                'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300'}`}>
              {lesson.data.difficulty}
            </span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-stone-100 text-stone-600 dark:bg-stone-800 dark:text-stone-400">
              ≈{lesson.data.durationMin} мин
            </span>
            {lesson.data.status === 'черновик' && (
              <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300">
                черновик
              </span>
            )}
            {lesson.data.prerequisite && (
              <a
                href={`${base}course/${lesson.data.prerequisite}`}
                class="text-xs px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 dark:bg-blue-950/30 dark:text-blue-400 hover:underline"
              >
                ← Сначала: {lesson.data.prerequisite.split('/').pop()}
              </a>
            )}
          </div>

          <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-3">{lesson.data.title}</h1>
          <p class="text-lg text-stone-600 dark:text-stone-400">{lesson.data.summary}</p>

          {lesson.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {lesson.data.tags.map(tag => (
                <a href={`${base}glossary`} class="text-xs px-2 py-1 rounded-md bg-stone-100 text-stone-600 dark:bg-stone-800 dark:text-stone-400 hover:bg-wine-50 dark:hover:bg-wine-950/30 hover:text-wine-700 dark:hover:text-wine-400 transition-colors">
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        <div class="prose-wine" data-pagefind-body>
          <slot />
        </div>

        <!-- Key Points, Mnemonic, Self-Check -->
        {lesson.data.keyPoints && lesson.data.keyPoints.length > 0 && (
          <KeyPoints
            client:load
            points={lesson.data.keyPoints}
            mnemonic={lesson.data.mnemonic}
            selfCheck={lesson.data.selfCheck}
          />
        )}

        {lesson.data.sources && lesson.data.sources.length > 0 && (
          <section class="mt-10 pt-6 border-t border-stone-200 dark:border-stone-800">
            <h3 class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wide mb-3">Источники</h3>
            <ul class="space-y-1">
              {lesson.data.sources.map(src => (
                <li class="text-sm text-stone-600 dark:text-stone-400 flex gap-2">
                  <span class="text-stone-400">—</span>
                  <span>{src}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Notes -->
        <LessonNotes client:load lessonId={lesson.id} />

        <LessonProgress lessonId={lesson.id} />

        <!-- Quick access to quiz/flashcards -->
        {(moduleQuizCount > 0 || moduleCardCount > 0) && (
          <div class="mt-6 p-4 rounded-xl bg-stone-50 dark:bg-stone-900 border border-stone-200 dark:border-stone-800">
            <p class="text-sm font-medium text-stone-700 dark:text-stone-300 mb-3">
              Закрепите знания по модулю «{module?.title}»:
            </p>
            <div class="flex flex-wrap gap-2">
              {moduleCardCount > 0 && (
                <a href={`${base}study?module=${lesson.data.module}`} class="btn-secondary text-xs">
                  🃏 Флэш-карты ({moduleCardCount})
                </a>
              )}
              {moduleQuizCount > 0 && (
                <a href={`${base}quiz?module=${lesson.data.module}`} class="btn-primary text-xs">
                  ❓ Пройти квиз ({moduleQuizCount} вопроса)
                </a>
              )}
            </div>
          </div>
        )}

        <!-- Navigation -->
        <nav class="mt-8 flex gap-4 justify-between">
          {prevLesson ? (
            <a href={`${base}course/${prevLesson.slug}`} class="btn-secondary flex-1 max-w-xs">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              <span class="truncate">{prevLesson.title}</span>
            </a>
          ) : <div class="flex-1 max-w-xs" />}

          {nextLesson ? (
            <a href={`${base}course/${nextLesson.slug}`} class="btn-primary flex-1 max-w-xs justify-end">
              <span class="truncate">{nextLesson.title}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : <div class="flex-1 max-w-xs" />}
        </nav>
      </article>

      <!-- Right TOC -->
      <aside class="hidden xl:block w-56 flex-shrink-0">
        <div class="sticky top-24">
          <LessonTOC headings={headings} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
